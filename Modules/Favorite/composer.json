{
    "name": "alirezajavadi/favorite",
    "description": "Favorite management module with polymorphic favorites for movies, series, and articles.",
    "authors": [
        {
            "name": "Alireza Javadi",
            "email": "alirezajavadigit@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "extra": {
        "laravel": {
            "providers": [],
            "aliases": {}
        }
    },
    "autoload": {
        "psr-4": {
            "Modules\\Favorite\\": "app/",
            "Modules\\Favorite\\Database\\Factories\\": "database/factories/",
            "Modules\\Favorite\\Database\\Seeders\\": "database/seeders/"
