# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME="Modular Movie Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=movies_db
DB_USERNAME=movies_user
DB_PASSWORD=

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=movies_

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS S3 (optional — for media uploads) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Module metadata ──────────────────────────────────────────────────────────
MODULE_VENDOR=
MODULE_AUTHOR_NAME=
MODULE_AUTHOR_EMAIL=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

AUTH_GUARD=api

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# ─── Docker ───────────────────────────────────────────────────────────────────
UID=1000
GID=1000

# ─── Movie uploads ────────────────────────────────────────────────────────────
# local | s3
MOVIE_UPLOAD_DISK=local

# ─── ZarinPal ────────────────────────────────────────────────────────────────
ZARINPAL_SANDBOX=true
ZARINPAL_MERCHANT_ID=

# ─── PayPal ───────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_CALLBACK_URL=http://localhost:8080/api/v1/payments/callback/paypal
PAYPAL_CANCEL_URL=http://localhost:8080/payment/paypal/cancel

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CALLBACK_URL=http://localhost:8080/api/v1/payments/callback/stripe
STRIPE_CANCEL_URL=http://localhost:8080/api/v1/payments/callback/stripe

# ─── Frontend ─────────────────────────────────────────────────────────────────
PAYMENT_FRONTEND_REDIRECT_URL=http://localhost:3000/account/subscriptions
